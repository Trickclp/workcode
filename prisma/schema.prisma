// Esquema de base de datos de Work.Code.
//
// Base de datos: Neon Postgres (la misma en desarrollo y producción,
// conectada vía Vercel Marketplace). DATABASE_URL es la conexión
// pooled para runtime; DATABASE_URL_UNPOOLED es la directa que usan
// las migraciones (requisito de Prisma con poolers como pgbouncer).
//
// Los campos *Json guardan estructuras (casos de prueba, escala,
// política de atraso, resultados) serializadas; los mappers de
// lib/server/work.ts las convierten al shape del cliente.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DATABASE_URL_UNPOOLED")
}

model User {
  id           String   @id @default(cuid())
  name         String
  email        String   @unique
  passwordHash String?
  role         String? // "alumno" | "profesor" | null (Google sin onboarding)
  provider     String   @default("password")
  createdAt    DateTime @default(now())
}

model ClassRoom {
  id           String       @id @default(cuid())
  name         String
  code         String       @unique
  teacherEmail String
  studentsJson String       @default("[]")
  assignments  Assignment[]
}

model Assignment {
  id             String       @id @default(cuid())
  classId        String
  class          ClassRoom    @relation(fields: [classId], references: [id], onDelete: Cascade)
  title          String
  instructions   String
  language       String
  testCasesJson  String       @default("[]")
  dueDate        String
  scaleJson      String
  weight         Int
  latePolicyJson String
  submissions    Submission[]
}

model Submission {
  id             String     @id @default(cuid())
  assignmentId   String
  assignment     Assignment @relation(fields: [assignmentId], references: [id], onDelete: Cascade)
  studentEmail   String
  code           String
  passed         Int
  total          Int
  score          Float?
  status         String     @default("auto")
  isLate         Boolean    @default(false)
  penaltyApplied Int        @default(0)
  submittedAt    DateTime   @default(now())
  outcomesJson   String     @default("[]")
}
