# ── Work.Code — variables de entorno ─────────────────────────────
# El proyecto incluye un .env local ya funcional. Este archivo es la
# referencia para nuevos entornos (otro PC, Vercel, VPS).

# Base de datos (Prisma).
# Desarrollo: SQLite local. Producción: URL de Postgres
# (Vercel Postgres / Supabase / Neon) + provider "postgresql" en
# prisma/schema.prisma.
DATABASE_URL="file:./dev.db"

# Secreto de sesión de NextAuth (obligatorio).
# Genera uno con: npx auth secret   (o cualquier cadena aleatoria larga)
AUTH_SECRET=

# Google OAuth (opcional — el login con correo/contraseña funciona sin esto).
# Créalas en Google Cloud Console → Credentials → OAuth client ID (Web).
# Redirect URI: http://localhost:3000/api/auth/callback/google
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# AI Tutor con Claude (opcional; sin clave se usa el tutor local).
# Clave en https://platform.claude.com
ANTHROPIC_API_KEY=

# Motor de ejecución remota para C/C++/Java/Rust/Go/PHP/Ruby.
# Por defecto: Wandbox (público y gratuito, sin clave).
# Producción recomendada: Piston autoalojado en Docker:
#   docker run -d -p 2000:2000 ghcr.io/engineer-man/piston
#   EXECUTION_PROVIDER=piston
#   EXECUTION_API_URL=http://localhost:2000/api/v2
EXECUTION_PROVIDER=
EXECUTION_API_URL=
